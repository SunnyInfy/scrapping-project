{
  "name": "scrapping-project",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build:shared": "npm run build --workspace=shared",
    "build:backend": "npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build": "npm-run-all build:shared build:backend build:frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev": "npm-run-all build:shared --parallel dev:backend dev:frontend"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "gsd": "^0.0.3"
  },
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "@types/node": "^25.9.3",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}